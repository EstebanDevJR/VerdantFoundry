# Verdant Foundry - Environment Variables
# Copy to .env and configure
# Copy this file to .env and fill in the values

# ============ API Gateway (NestJS) ============
NODE_ENV=development
PORT=4000
API_PREFIX=api

# JWT
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://verdant:verdant_secret@localhost:5433/verdant_foundry

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://verdant:verdant_secret@localhost:5672
RABBITMQ_RESEARCH_QUEUE=research.tasks
RABBITMQ_TOOL_QUEUE=tool.tasks
RABBITMQ_MEMORY_QUEUE=memory.tasks
RABBITMQ_SIMULATION_QUEUE=simulation.tasks
RABBITMQ_EXPERIMENT_QUEUE=experiment.tasks

# AI Engine (internal calls)
AI_ENGINE_URL=http://localhost:8000

# Internal API (AI Engine -> Core updates)
INTERNAL_API_SECRET=verdant-internal-secret

# CORS
CORS_ORIGIN=http://localhost:3000

# ============ AI Engine (FastAPI) ============
AI_PORT=8000
REDIS_URL=redis://localhost:6379
CORE_API_URL=http://localhost:4000/api
INTERNAL_API_SECRET=verdant-internal-secret

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=verdant_memory

# LLM Providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Default LLM
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
